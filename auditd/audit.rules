# SOC-Lab Auditd Rules
# Phase 1: OS-level auditing for S5 (File Tampering) and S6 (Privilege Escalation)

# First, delete all existing rules
-D

# Set buffer size
-b 8192

# Set failure mode (1 = printk, 2 = panic)
-f 1

# ============================================
# S5: Important File Monitoring
# ============================================

# Monitor /etc/passwd for modifications
-w /etc/passwd -p wa -k passwd_changes

# Monitor /etc/shadow for modifications
-w /etc/shadow -p wa -k shadow_changes

# Monitor /etc/group for modifications
-w /etc/group -p wa -k group_changes

# Monitor /etc/sudoers for modifications
-w /etc/sudoers -p wa -k sudoers_changes
-w /etc/sudoers.d -p wa -k sudoers_changes

# Monitor SSH configuration
-w /etc/ssh/sshd_config -p wa -k sshd_config_changes

# Monitor cron jobs
-w /etc/crontab -p wa -k cron_changes
-w /etc/cron.d -p wa -k cron_changes
-w /etc/cron.daily -p wa -k cron_changes
-w /etc/cron.hourly -p wa -k cron_changes
-w /etc/cron.monthly -p wa -k cron_changes
-w /etc/cron.weekly -p wa -k cron_changes
-w /var/spool/cron -p wa -k cron_changes

# Monitor system binaries
-w /bin -p wa -k bin_changes
-w /sbin -p wa -k sbin_changes
-w /usr/bin -p wa -k usr_bin_changes
-w /usr/sbin -p wa -k usr_sbin_changes

# Monitor /etc/hosts and DNS configuration
-w /etc/hosts -p wa -k hosts_changes
-w /etc/resolv.conf -p wa -k dns_changes

# Monitor application directory (if applicable)
-w /var/www -p wa -k app_changes
-w /app -p wa -k app_changes

# ============================================
# S6: Privilege Escalation Monitoring
# ============================================

# Monitor sudo usage
-w /usr/bin/sudo -p x -k sudo_usage
-w /bin/su -p x -k su_usage

# Monitor privilege escalation syscalls (64-bit)
-a always,exit -F arch=b64 -S setuid -S setgid -S setreuid -S setregid -k privilege_escalation
-a always,exit -F arch=b64 -S setresuid -S setresgid -k privilege_escalation

# Monitor execution with root privileges (euid=0 but auid!=0)
-a always,exit -F arch=b64 -S execve -F euid=0 -F auid!=0 -F auid!=4294967295 -k privilege_escalation

# Monitor privilege escalation syscalls (32-bit for compatibility)
-a always,exit -F arch=b32 -S setuid -S setgid -S setreuid -S setregid -k privilege_escalation
-a always,exit -F arch=b32 -S setresuid -S setresgid -k privilege_escalation
-a always,exit -F arch=b32 -S execve -F euid=0 -F auid!=0 -F auid!=4294967295 -k privilege_escalation

# Monitor SUID/SGID file execution
-a always,exit -F arch=b64 -S execve -C euid!=uid -F euid=0 -k setuid_execution
-a always,exit -F arch=b32 -S execve -C euid!=uid -F euid=0 -k setuid_execution

# ============================================
# User and Session Monitoring
# ============================================

# Monitor user/group management commands
-w /usr/sbin/useradd -p x -k user_management
-w /usr/sbin/userdel -p x -k user_management
-w /usr/sbin/usermod -p x -k user_management
-w /usr/sbin/groupadd -p x -k group_management
-w /usr/sbin/groupdel -p x -k group_management
-w /usr/sbin/groupmod -p x -k group_management

# Monitor password changes
-w /usr/bin/passwd -p x -k password_changes

# Monitor login configuration
-w /etc/login.defs -p wa -k login_config
-w /etc/pam.d -p wa -k pam_config

# ============================================
# Network Configuration Monitoring
# ============================================

# Monitor network configuration
-w /etc/network -p wa -k network_config
-w /etc/sysconfig/network -p wa -k network_config

# Monitor iptables/firewall rules
-w /etc/iptables -p wa -k firewall_config
-w /sbin/iptables -p x -k firewall_changes

# ============================================
# System Startup Monitoring
# ============================================

# Monitor init scripts
-w /etc/init.d -p wa -k init_changes
-w /etc/systemd -p wa -k systemd_changes

# Monitor kernel modules
-w /sbin/insmod -p x -k kernel_modules
-w /sbin/rmmod -p x -k kernel_modules
-w /sbin/modprobe -p x -k kernel_modules

# ============================================
# Process and Execution Monitoring
# ============================================

# Monitor process creation with specific interpreters
-a always,exit -F arch=b64 -S execve -F path=/bin/sh -k shell_execution
-a always,exit -F arch=b64 -S execve -F path=/bin/bash -k shell_execution
-a always,exit -F arch=b64 -S execve -F path=/usr/bin/python -k script_execution
-a always,exit -F arch=b64 -S execve -F path=/usr/bin/python3 -k script_execution
-a always,exit -F arch=b64 -S execve -F path=/usr/bin/perl -k script_execution

# ============================================
# Make the configuration immutable
# ============================================
# Uncomment the following line to lock the audit configuration
# -e 2

