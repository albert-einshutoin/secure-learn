# ============================================
# Application Configuration
# ============================================
NODE_ENV=production
LOG_PATH=/var/log/app

# ============================================
# Database Configuration (PostgreSQL)
# ============================================
DB_HOST=db
DB_PORT=5432
DB_USER=soclab
DB_PASS=soclab_password
DB_NAME=soclab

# PostgreSQL Environment (for docker-compose)
POSTGRES_USER=soclab
POSTGRES_PASSWORD=soclab_password
POSTGRES_DB=soclab

# ============================================
# Elasticsearch Configuration
# ============================================
# Elasticsearch Java Options (memory settings)
ES_JAVA_OPTS=-Xms1g -Xmx1g

# Elasticsearch Cluster Name
ELASTICSEARCH_CLUSTER_NAME=soc-lab

# Elasticsearch Hosts (for Kibana/Filebeat)
ELASTICSEARCH_HOSTS=http://elasticsearch:9200

# ============================================
# Kibana Configuration
# ============================================
KIBANA_SERVER_NAME=soc-lab-kibana
XPACK_SECURITY_ENABLED=false

# ============================================
# Fail2ban Configuration
# ============================================
TZ=Asia/Tokyo
F2B_LOG_LEVEL=INFO

# ============================================
# ElastAlert Configuration (Phase 2)
# ============================================
# Slack Webhook URL for notifications
# Get this from: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ============================================
# Exercise Mode Configuration (Phase 3)
# ============================================
# Team assignment (RED or BLUE)
TEAM=RED

# Target IP for exercise scenarios
TARGET_IP=172.32.0.100

# Exercise timing
EXERCISE_START_TIME=
EXERCISE_DURATION=3600

# ============================================
# Network Configuration (Optional)
# ============================================
# Attack Network Subnet
ATTACK_NET_SUBNET=172.18.0.0/24

# Application Network Subnet
APP_NET_SUBNET=172.19.0.0/24

# Monitor Network Subnet
MONITOR_NET_SUBNET=172.21.0.0/24