{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://secure-learn.dev/schema/lab.schema.json",
  "title": "Secure Learn lab manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "version",
    "title",
    "track",
    "mode",
    "maturity",
    "platforms",
    "standards",
    "prerequisites",
    "safety",
    "workflow",
    "evidence",
    "assessment"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "version": { "type": "integer", "minimum": 1 },
    "title": { "type": "string", "minLength": 1 },
    "track": { "type": "string", "minLength": 1 },
    "mode": {
      "type": "string",
      "enum": ["docker-lab", "host-assisted", "operator-workflow", "design-exercise"]
    },
    "maturity": {
      "type": "string",
      "enum": ["documented", "runnable", "verified", "external"]
    },
    "platforms": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "optional"],
      "properties": {
        "required": { "$ref": "#/$defs/stringArray" },
        "optional": { "$ref": "#/$defs/stringArray" }
      }
    },
    "standards": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mitre_attack", "owasp_api", "cwe", "nist_csf"],
      "properties": {
        "mitre_attack": { "$ref": "#/$defs/stringArray" },
        "owasp_api": { "$ref": "#/$defs/stringArray" },
        "cwe": { "$ref": "#/$defs/stringArray" },
        "nist_csf": { "$ref": "#/$defs/stringArray" }
      }
    },
    "prerequisites": { "$ref": "#/$defs/stringArray" },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_services", "allowed_cidrs", "external_network"],
      "properties": {
        "target_services": { "$ref": "#/$defs/stringArray" },
        "allowed_cidrs": { "$ref": "#/$defs/stringArray" },
        "external_network": { "const": false }
      }
    },
    "workflow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["attack", "verify", "remediate", "regress"],
      "properties": {
        "attack": { "$ref": "#/$defs/nullableExecutionSpec" },
        "verify": { "$ref": "#/$defs/nullableExecutionSpec" },
        "remediate": { "$ref": "#/$defs/nullableExecutionSpec" },
        "regress": { "$ref": "#/$defs/nullableExecutionSpec" }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required"],
      "properties": { "required": { "$ref": "#/$defs/nonEmptyStringArray" } }
    },
    "assessment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "verifier"],
      "properties": {
        "mode": { "type": "string", "minLength": 1 },
        "verifier": { "$ref": "#/$defs/nullableExecutionSpec" }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "maturity": { "enum": ["runnable", "verified"] } },
        "required": ["maturity"]
      },
      "then": {
        "properties": {
          "workflow": {
            "type": "object",
            "properties": {
              "attack": { "$ref": "#/$defs/executionSpec" },
              "verify": { "$ref": "#/$defs/nullableExecutionSpec" },
              "remediate": { "$ref": "#/$defs/nullableExecutionSpec" },
              "regress": { "$ref": "#/$defs/nullableExecutionSpec" }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": { "maturity": { "const": "verified" } },
        "required": ["maturity"]
      },
      "then": {
        "properties": {
          "workflow": {
            "type": "object",
            "properties": {
              "verify": { "$ref": "#/$defs/executionSpec" },
              "remediate": { "$ref": "#/$defs/executionSpec" },
              "regress": { "$ref": "#/$defs/executionSpec" }
            }
          },
          "assessment": {
            "type": "object",
            "properties": { "verifier": { "$ref": "#/$defs/executionSpec" } }
          }
        }
      }
    }
  ],
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "nonEmptyStringArray": {
      "allOf": [
        { "$ref": "#/$defs/stringArray" },
        { "type": "array", "minItems": 1 }
      ]
    },
    "logicalPath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*//)(?!.*(?:^|/)\\.{1,2}(?:/|$))[A-Za-z0-9._@+=,-]+(?:/[A-Za-z0-9._@+=,-]+)*$"
    },
    "executionSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "args"],
      "properties": {
        "path": { "$ref": "#/$defs/logicalPath" },
        "args": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[^\\u0000-\\u001F\\u007F\\u0080-\\u009F]*$"
          }
        }
      }
    },
    "nullableExecutionSpec": {
      "anyOf": [
        { "$ref": "#/$defs/executionSpec" },
        { "type": "null" }
      ]
    }
  }
}
