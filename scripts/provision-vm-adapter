#!/usr/bin/node
'use strict';

const { provisionVmAdapter } = require('./lib/vm-adapter');

const SNAPSHOT_ID = /^[A-Za-z0-9][A-Za-z0-9._-]{7,127}$/;

function main(argv = process.argv.slice(2), options = {}) {
  const stdout = options.stdout || process.stdout;
  const stderr = options.stderr || process.stderr;
  const provision = options.provision || provisionVmAdapter;
  if (
    argv.length !== 2
    || !SNAPSHOT_ID.test(argv[0])
    || argv[0].includes('..')
    || argv[1] !== '--acknowledge-disposable-snapshot'
  ) {
    stderr.write('Usage: scripts/provision-vm-adapter <snapshot-id> --acknowledge-disposable-snapshot\n');
    return 2;
  }
  try {
    const marker = provision({ snapshotId: argv[0], acknowledge: true });
    stdout.write(`${JSON.stringify(marker, null, 2)}\n`);
    return 0;
  } catch {
    // Never reflect platform probes, paths, or untrusted input.
    stderr.write('VM adapter could not be provisioned.\n');
    return 1;
  }
}

if (require.main === module) process.exitCode = main();

module.exports = { main };
