#!/usr/bin/env node
'use strict';

const { provisionVmAdapter } = require('./lib/vm-adapter');

const SNAPSHOT_ID = /^[A-Za-z0-9][A-Za-z0-9._-]{7,127}$/;

function main(argv = process.argv.slice(2)) {
  if (
    argv.length !== 2
    || !SNAPSHOT_ID.test(argv[0])
    || argv[0].includes('..')
    || argv[1] !== '--acknowledge-disposable-snapshot'
  ) {
    process.stderr.write('Usage: scripts/provision-vm-adapter <snapshot-id> --acknowledge-disposable-snapshot\n');
    return 2;
  }
  try {
    provisionVmAdapter({ snapshotId: argv[0], acknowledge: true });
    process.stdout.write('Local Linux VM adapter provisioned.\n');
    return 0;
  } catch {
    // Never reflect platform probes, paths, or untrusted input.
    process.stderr.write('VM adapter could not be provisioned.\n');
    return 1;
  }
}

if (require.main === module) process.exitCode = main();

module.exports = { main };
