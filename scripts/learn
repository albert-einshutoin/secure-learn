#!/usr/bin/env node
'use strict';

const fs = require('node:fs');
const path = require('node:path');
const { loadManifests, loadStandards } = require('./lib/curriculum');
const { doctorManifest } = require('./lib/doctor');

const REPOSITORY_ROOT = fs.realpathSync(path.resolve(__dirname, '..'));
const SAFE_INPUT = /^[A-Za-z0-9][A-Za-z0-9-]{0,63}$/;

function findManifest(manifests, id) {
  return manifests.find((manifest) => manifest.id === id);
}

function main(argv = process.argv.slice(2)) {
  // Validate before loading data or reflecting values so control sequences and
  // oversized arguments never cross a diagnostic boundary.
  if (argv.some((value) => typeof value !== 'string' || !SAFE_INPUT.test(value))) {
    process.stderr.write('Invalid command input.\n');
    return 2;
  }
  const [command, ...args] = argv;
  const manifests = loadManifests(REPOSITORY_ROOT);

  if (command === 'list' && args.length === 0) {
    process.stdout.write(manifests.map((manifest) => [
      manifest.id,
      manifest.maturity,
      manifest.platforms.required.join(','),
      manifest.title,
    ].join('\t')).join('\n') + '\n');
    return 0;
  }

  if (command === 'show' && args.length === 1) {
    const manifest = findManifest(manifests, args[0]);
    if (!manifest) {
      process.stderr.write(`Unknown lab '${args[0]}'.\n`);
      return 2;
    }
    process.stdout.write(`${JSON.stringify(manifest, null, 2)}\n`);
    return 0;
  }

  if (command === 'validate' && args.length === 0) {
    loadStandards(REPOSITORY_ROOT);
    process.stdout.write(`Validated ${manifests.length} lab manifests.\n`);
    return 0;
  }

  if (command === 'doctor' && args.length === 1) {
    const manifest = findManifest(manifests, args[0]);
    if (!manifest) {
      process.stderr.write(`Unknown lab '${args[0]}'.\n`);
      return 2;
    }
    try {
      process.stdout.write(doctorManifest(manifest, { repositoryRoot: REPOSITORY_ROOT }));
      return 0;
    } catch (error) {
      process.stderr.write(`${error.message}\n`);
      return 1;
    }
  }

  const displayName = command === undefined ? '' : command;
  process.stderr.write(`Command '${displayName}' is reserved for the executable-lab slices.\n`);
  return 2;
}

if (require.main === module) {
  try {
    process.exitCode = main();
  } catch {
    process.stderr.write('Curriculum data could not be loaded.\n');
    process.exitCode = 1;
  }
}

module.exports = { main };
