{
  "name": "soc-lab-app",
  "version": "1.0.0",
  "description": "Remediated NestJS application for local SOC training",
  "author": "SOC-Lab",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "build": "nest build",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run build",
    "test": "npm run build && npm run test:unit",
    "test:unit": "node --test test/*.test.js",
    "test:integration": "npm run build && RUN_DB_INTEGRATION=1 node --test test/users.integration.test.js",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-express": "^11.1.27",
    "express-rate-limit": "^8.5.2",
    "pg": "^8.11.3",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.1.0",
    "@types/express": "^5.0.6",
    "@types/node": "^24.13.3",
    "@types/pg": "^8.11.11",
    "typescript": "^7.0.2"
  },
  "overrides": {
    "multer": "^2.2.0"
  }
}
